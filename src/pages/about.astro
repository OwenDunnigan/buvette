---
import Layout from '../layouts/Layout.astro';

const { vibe } = Astro.locals;
---

<Layout title="About">
  <!-- Scroll-responsive App Bar -->
  <header id="about-app-bar" class={`fixed top-0 left-0 right-0 z-50 py-4 transition-transform duration-300 ${vibe.social.jetsStatus === 'VICTORY' ? 'mt-2' : ''}`} style="border-bottom: 2px dashed var(--theme-text); background-color: var(--theme-bg); color: var(--theme-text);">
      <div class="container mx-auto px-4 text-center md:text-left">
          <a href="/" class="text-4xl font-logo tracking-tight hover:opacity-70 transition-opacity">Buvette</a>
      </div>
  </header>

  <div class="w-full px-6 md:px-12 max-w-7xl mx-auto pt-28 pb-20">
      <div class="text-center mb-12 pb-4 border-b-2 border-stone-900 border-dashed">
        <h1 class="text-4xl font-display font-bold uppercase tracking-[0.2em]">About Us</h1>
        <p class="text-xs font-mono uppercase mt-2">Est. 2021 &mdash; Winnipeg, MB</p>
      </div>

      <div class="flex flex-col md:flex-row gap-12 items-start font-mono text-sm leading-relaxed">

        <!-- Left Column: Images (45%) -->
        <div class="w-full md:w-[45%] space-y-8 order-2 md:order-1">
            <div class="w-full bg-stone-200 border border-stone-900">
                <div class="aspect-video w-full overflow-hidden">
                    <img
                        src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=800&q=80"
                        alt="Restaurant Interior"
                        class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
                    />
                </div>
                <p class="text-[10px] p-2 text-center normal-case text-stone-500 bg-stone-100">The main dining room during golden hour.</p>
            </div>

            <div class="w-full bg-stone-200 border border-stone-900">
                <div class="grid grid-cols-2">
                    <div class="aspect-square overflow-hidden border-r border-stone-900">
                         <img
                            src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=600&q=80"
                            alt="Plating detail"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
                        />
                    </div>
                    <div class="aspect-square overflow-hidden">
                         <img
                            src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=600&q=80"
                            alt="Chef in kitchen"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
                        />
                    </div>
                </div>
                <p class="text-[10px] p-2 text-center normal-case text-stone-500 bg-stone-100 border-t border-stone-900">Seasonal plating & Kitchen preparation.</p>
            </div>
        </div>

        <!-- Right Column: Text (55%) -->
        <div class="w-full md:w-[55%] space-y-10 order-1 md:order-2">
            <p class="uppercase text-lg md:text-xl leading-relaxed" style="font-weight: 500;">
            Buvette is a cozy, plant-filled neighborhood eatery dedicated to the art of delicious food. Driven by the joy of creation, we combine fresh, seasonal ingredients with comforting classics, preparing every dish with imagination and heart.
            </p>

            <div class="py-4">
                <div class="border-l-4 border-stone-900 pl-6 italic normal-case text-xl md:text-2xl font-display text-stone-800">
                "It's not just about the food, it's about the moment."
                </div>
            </div>

            <p class="text-base md:text-lg leading-relaxed">
            Our kitchen focuses on creating dishes that strike the perfect balance between culinary creativity and warm, nostalgic comfort. Whether you are stopping by for our signature <b>Eggs Benedict Flight</b> on a Saturday, indulging in a limited time creation such as a <b>French Toast Breakfast Sausage Club Sandwich</b>, or discovering our famous <b>Spicy Cucumbers</b>, every plate is layered with flavor.
            <br>
            <br>
            Run by a passionate team that loves to make you feel right at home, Buvette isn't just a place to eat; it's an inviting third-place on the weekdays &ndash; bustling community eatery on the weekends. Whether you're a local regular or a weekend traveler looking for the best breakfast in the city, we invite you to grab a signature coffee, pull up a chair, and experience a taste of our home.
            </p>
        </div>

      </div>
  </div>
</Layout>

<script>
  function initAppBar() {
    const header = document.getElementById('about-app-bar');
    if (!header) return;

    let lastScroll = window.scrollY;

    const handleScroll = () => {
      const currentScroll = window.scrollY;
      
      // Add a small threshold to avoid jitter and bounce effects
      if (Math.abs(currentScroll - lastScroll) < 10) return;

      if (currentScroll > lastScroll && currentScroll > 60) {
        // Scrolling down -> hide the header entirely
        // -150% ensures it's completely off-screen including padding/margins
        header.style.transform = 'translateY(-150%)';
      } else {
        // Scrolling up -> show the header
        header.style.transform = 'translateY(0)';
      }
      
      lastScroll = currentScroll <= 0 ? 0 : currentScroll;
    };

    // Attach scroll listener
    window.addEventListener('scroll', handleScroll, { passive: true });

    // Clean up when view transitions out
    document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', handleScroll);
    }, { once: true });
  }

  // Initialize on full load or Astro view transition page load
  initAppBar();
  document.addEventListener('astro:page-load', initAppBar);
</script>
