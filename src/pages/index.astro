---
import Layout from '../layouts/Layout.astro';
import { getHeroOverlay, getDynamicMessage } from '../utils/tempColors';
import { getAllHolidayNames } from '../utils/holidays';
import InstagramCollage from '../components/InstagramCollage.astro';
import { fetchInstagramFeed } from '../utils/instagram';

const holidayNames = getAllHolidayNames();
const { vibe } = Astro.locals;

// Fetch Instagram images
const instagramFeed = await fetchInstagramFeed();
const currentHoliday = vibe.temporal.holiday.holidayName;

// Get temperature-based overlay
const overlay = getHeroOverlay(vibe.metrics.mentalTemp, vibe.social.jetsStatus, vibe.temporal.seasonBias, vibe.theme);

// Get dynamic message
const welcomeMessage = getDynamicMessage({
  temp: vibe.weather.temp,
  mentalTemp: vibe.metrics.mentalTemp,
  jetsStatus: vibe.social.jetsStatus,
  isGrind: vibe.grind.isGrind,
  grindDays: vibe.grind.coldStreakDays,
  todayMinTemp: vibe.grind.todayMinTemp,
  tomorrowMinTemp: vibe.grind.tomorrowMinTemp,
  dayAfterMinTemp: vibe.grind.dayAfterMinTemp,
  isColdSnapWarning: vibe.grind.isColdSnapWarning,
  holiday: vibe.temporal.holiday.holidayName,
  isBlackout: vibe.temporal.isBlackoutDate,
  deviation: vibe.metrics.deviation,
  deltaShock: vibe.metrics.deltaShock
});
---

<Layout title="Home" useDefaultContainer={false}>
  <!-- Floating About Link -->
  <a href="/about" 
     class="floating-about fixed top-6 right-6 z-1050 text-2xl font-bold uppercase transition-transform hover:scale-105" style="z-index:100;">
    About
  </a>

  <!-- Main Wrapper: Split on Desktop, Stacked on Mobile -->
  <div class="flex flex-col md:flex-row min-h-screen">

      <!-- LEFT COLUMN: Hero Video (Sticky on Desktop) -->
      <div class="w-full md:w-1/2 h-[100vh] md:h-[100vh] md:sticky md:top-0 md:self-start relative border-b md:border-b-0 md:border-r border-stone-200" style="background-color: var(--theme-bg);">

          <!-- Video Container with Parallax Hook -->
          <div class="parallax-video-container absolute inset-0 w-full h-full overflow-hidden z-0">
               <video
                  id="hero-video"
                  class="w-full h-full object-cover transition-transform duration-100 ease-linear will-change-transform"
                  autoplay
                  loop
                  muted
                  playsinline
                  poster="https://images.unsplash.com/photo-1556910103-1c02745a30bf?auto=format&fit=crop&w=800&q=80"
                  data-temp={vibe.weather.temp}
               >
                  <source src="/benny_SD.webm" type="video/mp4" />
               </video>
          </div>

          <!-- Temperature-Based Gradient Overlay -->
          <!-- -50°C = pink/purple, 0°C = blue, 30°C = red, 45°C = black -->
          <!-- Jets win = red + blue gradient -->
          <div 
            class="absolute inset-0 z-5 transition-all duration-1000 bg-gradient-pulse"
            style={`background: ${overlay.background}; mix-blend-mode: ${overlay.mixBlend};`}
            aria-hidden="true"
          ></div>

          <!-- Hero Content Overlay -->
          <div 
            class="absolute inset-0 z-10 flex flex-col items-center justify-center text-center p-8 pointer-events-none"
            style="color: var(--theme-hero-text);"
          >
               <h1 class="hero-text text-[6em] font-logo mb-4 drop-shadow-lg">Buvette</h1>
               <p class="text-xl md:text-2xl font-light tracking-wide drop-shadow-md max-w-md mb-6">
                 {welcomeMessage}
               </p>
               <p class="text-sm opacity-80 drop-shadow-sm">
                {vibe.weather.temp.toFixed(0)}&deg;C (Feels like {vibe.metrics.mentalTemp.toFixed(0)}&deg;C)
              </p>
          </div>
      </div>

      <!-- RIGHT COLUMN: Scrollable Content -->
      <div class="w-full md:w-1/2 transition-colors duration-1000 overflow-hidden" style="background-color: var(--theme-bg); color: var(--theme-text);">
           <!-- Content Container -->
           <div class="md:py-32 flex flex-col justify-center min-h-[120vh] space-y-16">

               <!-- Introduction -->
               <div class="text-center md:text-left space-y-8 p-8 md:p-16">
                   <p class="text-2xl md:text-3xl font-light leading-relaxed opacity-90">
                      Dedicated to the joy of <span class="italic font-display">eating</span> and <span class="italic font-display">drinking</span>.
                   </p>
                   <p class="font-mono text-sm leading-7 max-w-prose opacity-80">
                       Buvette is a place to gather, to share, and to enjoy the simple pleasures of life.
                       Our menu reflects the changing seasons and the best ingredients we can find.
                   </p>
                   <div>
                        <a href="/about" 
                          class="inline-block px-10 py-4 text-sm font-bold uppercase tracking-widest hover:scale-105 transition-all duration-300"
                          style="background-color: var(--theme-accent); color: var(--theme-bg);"
                       >
                          About Us
                       </a>
                   </div>
               </div>

               <!-- Hours & Location Grid -->
               <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 p-8 md:p-16">
                  <div class="p-8 shadow-sm border border-opacity-20 transition-colors duration-1000" 
                       style="background-color: var(--theme-surface); border-color: var(--theme-text);">
                      <h2 class="font-display text-2xl mb-4">Hours</h2>
                      <p class="mb-1"><strong>Tues - Fri:</strong> 9am - 3pm</p>
                      <p class="mb-1"><strong>Sat - Sun:</strong> 10am - 2pm</p>
                      <p class="mt-4 italic text-xs opacity-70">Walk-ins always welcome.</p>
                  </div>
                  <div class="p-8 shadow-sm border border-opacity-20 transition-colors duration-1000"
                       style="background-color: var(--theme-surface); border-color: var(--theme-text);">
                      <h2 class="font-display text-2xl mb-4">Location</h2>
                      <p class="mb-1">120 Scott Street</p>
                      <p class="mb-1">Winnipeg, MB</p>
                      <p class="mt-4"><a href="https://www.google.com/maps/dir/?api=1&destination=120+Scott+St,+Winnipeg,+MB+R3L+0K9" class="underline hover:opacity-80">Get Directions &rarr;</a></p>
                  </div>
               </div>

               <!-- Instagram Scattered Collage -->
               <div class="mt-16 mb-8 w-full">
                  <h2 class="font-display text-2xl text-center md:text-left opacity-90 pl-8 pb-4 md:pl-16">Latest...</h2>
                  <InstagramCollage images={instagramFeed} />
               </div>

           </div>
      </div>
  </div>
</Layout>

<script>
    // Parallax Effect for the Video
    let cleanupParallax: (() => void) | null = null;

    function handleScroll() {
        const videoElement = document.querySelector('.parallax-video-container video') as HTMLElement;
        if (!videoElement) return;

        const scrolled = window.scrollY;
        const isMobile = window.innerWidth < 768;

        if (isMobile) {
            // On Mobile: The container scrolls with the page.
            // We move the video DOWN (translateY > 0) to counteract the scroll UP.
            // This makes it look like a window.
            const speed = 0.5;
            videoElement.style.transform = `translateY(${scrolled * speed}px)`;
        } else {
            // On Desktop: The container is STICKY. It stays at top:0.
            // As we scroll the page (the right side scrolls), the sticky container stays.
            // We can add a subtle effect to make it feel less static, but 'sticky' is the main effect.
            // Let's add a very subtle 'drift' to show depth.
            const speed = 0.05;
            videoElement.style.transform = `scale(1.05) translateY(${scrolled * speed}px)`;
        }
    }

    function setupParallax() {
        // Clean up previous listener if it exists to be safe
        if (cleanupParallax) cleanupParallax();

        const videoElement = document.querySelector('.parallax-video-container video');
        if (!videoElement) return; // Not on this page or element not found

        window.addEventListener('scroll', handleScroll);

        cleanupParallax = () => {
            window.removeEventListener('scroll', handleScroll);
            cleanupParallax = null;
        };
    }

    function setupVideoPlayback() {
        const video = document.getElementById('hero-video') as HTMLVideoElement;
        if (!video) return;

        const tempStr = video.getAttribute('data-temp');
        if (!tempStr) return;


        const temp = parseFloat(tempStr);
        // Map -45 to +40 temperature range to 0.7 to 1.3 playback rate
        const minTemp = -45;
        const maxTemp = 40;
        const minRate = 0.7;
        const maxRate = 1.3;

        // Clamp temp
        const clampedTemp = Math.max(minTemp, Math.min(temp, maxTemp));

        // Calculate rate (linear interpolation)
        const rate = minRate + ((clampedTemp - minTemp) / (maxTemp - minTemp)) * (maxRate - minRate);

        // Wait for video metadata to load if not already
        if (video.readyState >= 1) {
            video.playbackRate = rate;
        } else {
            video.addEventListener('loadedmetadata', () => {
                video.playbackRate = rate;
            });
        }

        // Also update if video is played later to ensure it doesn't reset
        video.addEventListener('play', () => {
            video.playbackRate = rate;
        });
    }

    // Initialize immediately if script is executed
    setupVideoPlayback();

    // Astro View Transitions events
    document.addEventListener('astro:page-load', () => {
        setupParallax();
        setupVideoPlayback();
    });

    document.addEventListener('astro:before-swap', () => {
        if (cleanupParallax) cleanupParallax();
    });
</script>

<style>
  /* Floating About Link Theme Logic */
  .floating-about {
    /* Mobile: Placed over the video, needs light glowing text */
    color: var(--theme-hero-text);
    text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  }

  @media (min-width: 768px) {
    .floating-about {
      /* Desktop: Placed over the content background, needs standard text color */
      color: var(--theme-text);
      text-shadow: none;
    }
  }
</style>
