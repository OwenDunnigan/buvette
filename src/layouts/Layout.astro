---
import VibeInjector from '../components/VibeInjector.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
	title: string;
    useDefaultContainer?: boolean;
}

const { title, useDefaultContainer = true } = Astro.props;
const { vibe } = Astro.locals;
const { viscosity, windForce, temp } = vibe.weather;
const theme = vibe.theme;

const windSpeed = windForce * 50;
// Calculate tempMood: 0 (Cold -30) to 1 (Hot +30)
const tempMood = Math.min(Math.max((temp + 30) / 60, 0), 1);
---

<!doctype html>
<html lang="en" class="overflow-x-hidden" style={`--viscosity: ${viscosity}s; --wind-force: ${windForce}; --temp-mood: ${tempMood}; --primary-color: var(--theme-accent); --contrast-level: ${theme.effects.contrast / 100}; --blur-amount: ${theme.effects.blur};`}>
	<head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<VibeInjector currentTheme={theme} windSpeed={windSpeed} />
		<Analytics />
		<meta name="description" content="Buvette is primarily a cozy and delicious brunch spot in the Osborne Village area of Winnipeg, Manitoba. It focuses on rich food and fun vibes with a focus on ingredients and season. Sometimes we have even have evening events!" />
        <meta name="keywords" content="Buvette, Winnipeg restaurant, dynamic menu, queer-owned, women-run, local ingredients, seasonal food, cozy dining experience" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        <meta name="theme-color" media="(prefers-color-scheme: light)" content={theme.lightColors.bg} />
        <meta name="theme-color" media="(prefers-color-scheme: dark)" content={theme.darkColors.bg} />
		<title>{title} | Buvette</title>
	</head>
	<body class={`font-mono flex flex-col min-h-screen theme-${theme.id} overflow-x-hidden`}>
		{/* Victory Stripe - Jets Colors (Navy, Red, Silver, White) when they win */}
		{vibe.social.jetsStatus === 'VICTORY' && (
			<div class="fixed top-0 left-0 right-0 h-2 z-50 jets-victory-stripe" aria-label="Jets Victory Banner"></div>
		)}

        <main class={`flex-grow ${useDefaultContainer ? 'container mx-auto px-4 py-8' : ''}`}>
            <slot />
        </main>

        <footer class="p-6 border-t-2 border-dashed border-stone-900 dark:border-stone-700 relative">
            <div class="container mx-auto px-4">
                <!-- Location & Hours Section -->
                <div class="grid grid-cols-2 gap-4 mb-8 text-[10px] uppercase">
                    <div>
                        <h3 class="font-bold mb-1 border-b border-stone-300 dark:border-stone-700 inline-block">Location</h3>
                        <p>120 Scott St</p>
                        <p>Winnipeg, MB R3L 0K9</p>
                        <a 
                            href="https://www.google.com/maps/dir/?api=1&destination=120+Scott+St,+Winnipeg,+MB+R3L+0K9" 
                            target="_blank" 
                            rel="noopener noreferrer"
                            class="mt-2 text-[10px] underline cursor-pointer block"
                        >
                            Get Directions
                        </a>
                    </div>
                    <div class="max-w-[140px] justify-self-end w-full">
                        <h3 class="font-bold mb-1 border-b border-stone-300 dark:border-stone-700 inline-block">Hours</h3>
                        <div class="flex justify-between w-full">
                            <span>T-F</span>
                            <span>09:00-15:00</span>
                        </div>
                        <div class="flex justify-between w-full">
                            <span>S-S</span>
                            <span>10:00-14:00</span>
                        </div>
                    </div>
                </div>

                <div class="text-center">
                    <p class="uppercase text-m mb-2">We are proudly queer and women ran!</p>
                    <p class="font-bold uppercase text-lg mb-2">Thank You!</p>
                    <p class="text-xs uppercase mb-2">Please Come Again</p>
                    <p class="text-[10px] uppercase">&copy; {new Date().getFullYear()} Buvette EST.</p>
                </div>

                <div class="mt-6 flex justify-center text-xs">
                    <!-- Barcode simulation -->
                    <div class="text-center flex items-end gap-[2px]">
                            <p>Buvette is located on Treaty 1 territory, the home and traditional lands of the Anishinaabe (Ojibwe), Ininew (Cree), Anishininew (Oji-Cree), Dakota, and Dene people, and in the National Homeland of the Red River M&eacute;tis. Sourced from Shoal Lake 40 First Nation (Treaty 3), we recognize that our water supply came at the cost of the community&rsquo;s own access to safe drinking water for more than two decades. We remain mindful of this history and our ongoing responsibility to the people of Shoal Lake 40.</p>
                    </div>
                </div>
               
            </div>

            <!-- Jagged bottom edge using CSS gradient -->
            <div class="absolute left-0 right-0 h-4 footer-jagged-edge" style="bottom: -16px;"></div>
        </footer>
		<SpeedInsights />
	</body>
</html>

<style is:global>
    /* Jets Victory Strip */
    .jets-victory-stripe {
        background: repeating-linear-gradient(
            45deg,
            #041E42,
            #041E42 20px,
            #C8102E 20px,
            #C8102E 40px,
            #ffffff 40px,
            #ffffff 45px,
            #7B858D 45px,
            #7B858D 60px,
            #ffffff 60px,
            #ffffff 65px
        );
    }

    /* Light & Dark Mode Jagged Edge (Uses Theme Background) */
    .footer-jagged-edge {
        background: linear-gradient(45deg, transparent 33.333%, var(--theme-bg) 33.333%, var(--theme-bg) 66.667%, transparent 66.667%), 
                    linear-gradient(-45deg, transparent 33.333%, var(--theme-bg) 33.333%, var(--theme-bg) 66.667%, transparent 66.667%);
        background-size: 20px 40px;
        background-position: 0 -20px;
        transition: background 0.8s ease;
    }
    :root {
        --font-display: 'Recursive', sans-serif;
        --font-mono: 'IBM Plex Mono', monospace;

        /* Calculated Font Axes */
        /* Prefer using --type-slant and --type-weight injected by VibeInjector */
        --font-casual: var(--temp-mood);             /* Stiff or Loose */
    }

    body {
        transition: background-color calc(0.5s * var(--viscosity));
    }

    .font-display {
        font-family: var(--font-display);
        font-variation-settings:
            'MONO' 0,                   /* Proportional (Readable) */
            'CASL' var(--font-casual),  /* Reacts to Temp */
            'slnt' var(--type-slant),   /* Reacts to Wind */
            'wght' var(--type-weight);
    }

    .font-mono {
        font-family: var(--font-mono);
    }

    /* 1. HEADLINES (The "Voice") */
    @keyframes windSway {
        0%, 100% {
            transform: skewX(calc(var(--wind-force-ratio) * 1deg)) translateX(calc(var(--wind-force-ratio) * -1px));
        }
        50% {
            transform: skewX(calc(var(--wind-force-ratio) * -2deg)) translateX(calc(var(--wind-force-ratio) * 1px));
        }
    }

    /* 1. HEADLINES (The "Voice") */
    h1, h2, .hero-text, .text-3xl {
        font-family: var(--font-display);
        font-variation-settings:
            'MONO' 0,                   /* Proportional (Readable) */
            'CASL' var(--font-casual),  /* Reacts to Temp */
            'slnt' var(--type-slant),   /* Reacts to Wind */
            'wght' var(--type-weight);

        /* The swaying animation is proportional to wind force */
        display: inline-block; /* Required for transform to work effectively */
        animation: windSway calc(4s - (var(--wind-force-ratio) * 2s)) ease-in-out infinite alternate;
        transform-origin: bottom center;
    }

    /* Override display block if needed by specific elements like standard h2 that shouldn't break layout too much */
    h1, h2, .text-3xl {
        display: block; /* Typically block elements, but animation needs origin */
    }

    .hero-text {
        text-shadow: var(--theme-glow, 0 2px 4px rgba(0,0,0,0.5));
        transition: text-shadow 1s ease, opacity 1s ease;
        display: block; /* Kept block for layout */
    }

    @keyframes nightSparkle {
        0%, 100% { 
            text-shadow: var(--theme-glow, 0 0 10px rgba(0,0,0,0.5)), 0 0 20px var(--theme-hero-text); 
            opacity: 0.9; 
        }
        50% { 
            text-shadow: var(--theme-glow, 0 0 10px rgba(0,0,0,0.5)), 0 0 40px var(--theme-hero-text), 0 0 60px var(--theme-hero-text); 
            opacity: 1; 
        }
        75% { 
            text-shadow: var(--theme-glow, 0 0 10px rgba(0,0,0,0.5)), 0 0 30px var(--theme-hero-text); 
            opacity: 0.95; 
        }
    }

    @media (prefers-color-scheme: dark) {
        .hero-text {
            /* Keep both animations */
            animation:
                windSway calc(4s - (var(--wind-force-ratio) * 2s)) ease-in-out infinite alternate,
                nightSparkle 5s ease-in-out infinite alternate;
        }
    }

    @keyframes gradientPulse {
        0% { background-position: 0% 50%; opacity: 0.8; }
        50% { background-position: 100% 50%; opacity: 1.0; }
        100% { background-position: 0% 50%; opacity: 0.8; }
    }

    .bg-gradient-pulse {
        background-size: 200% 200% !important;
        animation: gradientPulse 15s ease infinite;
    }

    /* 2. THE BIG DATA (The "gauge") */
    .weather-display .temp-number {
        font-family: 'Recursive', monospace; /* Switch to Mono for alignment */
        font-variation-settings:
            'MONO' 1,                   /* Force Monospace for numbers */
            'CASL' 0,                   /* Keep numbers looking technical/stiff */
            'slnt' var(--type-slant),   /* But let them LEAN in the wind */
            'wght' 700;
    }

    /* 3. BODY COPY (The "Anchor") */
    body, p, .menu-item {
        font-family: 'IBM Plex Mono', monospace; /* Static, legible, industrial */
        font-weight: 400;
    }

    /* The "Sun Lie" / Glare Logic */
    .glare-overlay {
        opacity: var(--contrast-level);
        filter: blur(var(--blur-amount));
    }

    .font-logo {
        font-family: 'Sono', monospace;
        /* Note: Sono doesn't have a 'slnt' axis by default on Google Fonts, but user wants it slanted by wind. We can use CSS transform if axis isn't supported, but let's see if we can just apply transform: skewX() */
        font-variation-settings: 'wght' 392, 'MONO' 0.47;
        font-weight: 392;
        display: inline-block;
        animation: windSway calc(4s - (var(--wind-force-ratio) * 2s)) ease-in-out infinite alternate;
        transform-origin: bottom center;
    }

    @font-face {
      font-family: 'IBM Plex Mono';
      src: url('/fonts/IBMPlexMono-Regular.ttf') format('truetype');
      font-weight: 400;
      font-style: normal;
    }

    @font-face {
      font-family: 'IBM Plex Mono';
      src: url('/fonts/IBMPlexMono-Medium.ttf') format('truetype');
      font-weight: 500;
      font-style: normal;
    }

    @font-face {
      font-family: 'IBM Plex Mono';
      src: url('/fonts/IBMPlexMono-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-style: normal;
    }

    @font-face {
      font-family: 'Recursive';
      src: url('/fonts/Recursive-VariableFont.ttf') format('truetype-variations');
      font-weight: 300 1000;
    }

    @font-face {
      font-family: 'Sono';
      src: url('/fonts/Sono-VariableFont.ttf') format('truetype-variations');
      font-weight: 200 800;
    }
</style>
