---
import type { InstagramMedia } from '../utils/instagram';

export interface Props {
  images: InstagramMedia[];
}

const { images = [] } = Astro.props;

// 11 "Neighborhoods" spread across the blue section
const neighborhoods = [
  { x: 5, y: 2 },   { x: 35, y: 8 },   { x: 65, y: 3 },  // Top Row
  { x: 12, y: 25 },  { x: 42, y: 32 },  { x: 68, y: 22 }, // Mid-Top
  { x: 4, y: 52 },   { x: 38, y: 58 },  { x: 62, y: 48 }, // Mid-Bottom
  { x: 15, y: 82 },  { x: 55, y: 85 }                     // Bottom Row
];

const scatteredImages = images.slice(0, 11).map((img, index, arr) => {
  const home = neighborhoods[index % neighborhoods.length];
  // Add this inside your .map() function
  const randomScale = (0.9 + Math.random() * 0.2).toFixed(2); // Scales between 0.9 and 1.1
  
  // INCREASED JITTER: This creates the "Overlap"
  // We allow them to wander up to 15% from their home base
  const jitterX = Math.floor(Math.random() * 15) - 7.5; 
  const jitterY = Math.floor(Math.random() * 12) - 6;
  
  // RANDOM ROTATION: -12 to +12 degrees
  const rotation = (Math.random() * 24 - 12).toFixed(1);

  return {
    ...img,
    rotation,
    randomScale,
    desktopLeft: home.x + jitterX,
    desktopTop: home.y + jitterY,
    // Freshest images get a higher z-index
    zIndex: arr.length - index,
  };
});
---

<div class="instagram-collage-wrapper w-full relative">
  {scatteredImages.length > 0 ? (
    <div id="insta-feed-container" class="grid grid-cols-2 gap-4 p-4 md:block md:gap-0 md:p-0">
      {scatteredImages.map((image) => (
        <a
          href={image.permalink || "https://www.instagram.com/buvette.inthevillage/"}
          target="_blank"
          rel="noopener noreferrer"
          class="polaroid-card group relative md:absolute"
          style={`
            --desktop-left: ${image.desktopLeft}%;
            --desktop-top: ${image.desktopTop}%;
            --desktop-rotation: ${image.rotation}deg;
            --base-z-index: ${image.zIndex};
            --random-scale: ${image.randomScale};
          `}
          aria-label={image.caption ? `View Instagram post: ${image.caption}` : "View Instagram post"}
        >
          <div class="polaroid-frame w-full md:w-[320px]">
            <div class="w-full aspect-square overflow-hidden bg-stone-100 flex items-center justify-center">
              <img
                src={image.media_type === 'VIDEO' ? (image.thumbnail_url || image.media_url) : image.media_url}
                alt={image.caption || "Instagram Post"}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center w-full min-h-[400px] text-stone-500 italic flex items-center justify-center h-full">
      <p>Stay tuned! Our recent moments are taking a moment to load.</p>
    </div>
  )}
</div>

<style>
  .instagram-collage-wrapper {
    padding: 2rem 0;
    overflow-x: clip;
  }

  .polaroid-frame {
    padding: 12px 12px 45px 12px;
    background: white;
    border: 1px solid #eaeaea;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    transition: box-shadow 0.4s ease;
  }

  .polaroid-card {
    will-change: transform, z-index, box-shadow;
    z-index: var(--base-z-index, 1);
  }

  @media (min-width: 768px) {
    #insta-feed-container {
      position: relative;
      width: 100%;
      height: 1200px; /* Reduced slightly to keep the photos cohesive */
      overflow: visible;
    }

    .polaroid-card {
      position: absolute;
      top: var(--desktop-top);
      left: var(--desktop-left);
      transform: rotate(var(--desktop-rotation)) scale(var(--random-scale));
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), z-index 0s;
      transform-origin: center center;
    }

    .polaroid-card:hover,
    .polaroid-card:focus {
      transform: scale(1.15) rotate(0deg) !important;
      z-index: 9999 !important; 
    }

    .polaroid-card:hover .polaroid-frame,
    .polaroid-card:focus .polaroid-frame {
      box-shadow: 0 30px 60px rgba(0,0,0,0.25);
    }
  }
</style>