---
import type { InstagramMedia } from '../utils/instagram';

export interface Props {
  images: InstagramMedia[];
}

const { images = [] } = Astro.props;

function getRandomRotation(min: number, max: number) {
  return Math.random() * (max - min) + min;
}

const scatteredImages = images.map((img, index) => ({
  ...img,
  // MESSY ROTATION: Random angle between -15 and +15 degrees
  rotation: getRandomRotation(-15, 15).toFixed(1),
  // FULL WIDTH SPREAD: Random left position between 5% and 75%
  desktopLeft: Math.floor(Math.random() * 70) + 5,
  // VERTICAL SPREAD: Random top position between 5% and 50%
  desktopTop: Math.floor(Math.random() * 45) + 5,
  // Base stacking order
  zIndex: index + 1,
}));
---

<div class="instagram-collage-wrapper w-full relative">
  {scatteredImages.length > 0 ? (
    <div id="insta-feed-container" class="flex flex-col items-center gap-8 md:block md:gap-0">
      {scatteredImages.map((image) => (
        <a
          href={image.permalink || "https://www.instagram.com/buvette.inthevillage/"}
          target="_blank"
          rel="noopener noreferrer"
          class="polaroid-card group relative md:absolute"
          style={`
            --desktop-left: ${image.desktopLeft}%;
            --desktop-top: ${image.desktopTop}%;
            --desktop-rotation: ${image.rotation}deg;
            --base-z-index: ${image.zIndex};
          `}
          aria-label={image.caption ? `View Instagram post: ${image.caption}` : "View Instagram post"}
        >
          <div class="polaroid-frame w-[280px] md:w-[300px]">
            <div class="w-full aspect-square overflow-hidden bg-stone-100 flex items-center justify-center">
              <img
                src={image.media_type === 'VIDEO' ? (image.thumbnail_url || image.media_url) : image.media_url}
                alt={image.caption || "Instagram Post"}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </div>
          </div>
        </a>
      ))
      }
    </div>
  ) : (
    <div class="text-center w-full min-h-[400px] text-stone-500 italic flex items-center justify-center h-full">
      <p>Stay tuned! Our recent moments are taking a moment to load.</p>
    </div>
  )}
</div>

<style>
  .instagram-collage-wrapper {
    /* Container wrapper */
    padding: 2rem 1rem;
    overflow-x: clip; /* allow full width on mobile without breaking x bounds */
  }

  /* Single column (Mobile) behavior is handled primarily by Tailwind Flex classes in the HTML. */
  /* Here we just apply the physical paper look */
  .polaroid-frame {
    padding: 12px 12px 45px 12px;
    background: white;
    border: 1px solid #eaeaea;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    transition: box-shadow 0.4s ease;
  }

  .polaroid-card {
    will-change: transform, z-index, box-shadow;
    z-index: var(--base-z-index, 1);
  }

  /* Desktop Styles: The Scattered Collage */
  @media (min-width: 768px) {
    #insta-feed-container {
      position: relative;
      width: 100%;
      height: 700px;
      margin-top: 40px;
      overflow: visible;
    }

    .polaroid-card {
      position: absolute;
      top: var(--desktop-top);
      left: var(--desktop-left);
      transform: rotate(var(--desktop-rotation));
      /* The cubic-bezier adds a high-end "spring" effect to the hover */
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), z-index 0.4s;
      transform-origin: center center;
    }

    /* THE HOVER MAGIC */
    .polaroid-card:hover,
    .polaroid-card:focus {
      transform: scale(1.15) rotate(0deg) !important;
      z-index: 9999 !important; /* Forces the hovered photo to the very front */
    }

    .polaroid-card:hover .polaroid-frame,
    .polaroid-card:focus .polaroid-frame {
      box-shadow: 0 30px 60px rgba(0,0,0,0.25);
    }
  }
</style>